APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/editorial_data

REQUEST_TIMEOUT_SECONDS=20
REQUEST_RETRIES=3
REQUEST_BACKOFF_SECONDS=1

AEMET_API_KEY=
CNMV_REGISTRY_URL=
COUNTRY_OVERVIEW_BDE_URL=
COUNTRY_OVERVIEW_INE_URL=
COUNTRY_OVERVIEW_EUROSTAT_URL=
COUNTRY_OVERVIEW_OECD_URL=
COUNTRY_OVERVIEW_FMI_URL=
COUNTRY_OVERVIEW_SERIES_MAP=
# Ejemplo (incluye IDs digitales nuevos listos para mapear):
# COUNTRY_OVERVIEW_SERIES_MAP=inflation=ine:IPC290750,population=ine:ECP320,demo-population=ine:ECP320,unemployment=ine:EPA452434,laboral-employment=ine:EPA87,laboral-activity-rate=ine:EPA77038,laboral-unemployment-harmonized=fmi:ESP:LUR,debt=fmi:ESP:GGXWDG_NGDP,public-balance=fmi:ESP:GGXCNL_NGDP,resumen-balance=fmi:ESP:GGXCNL_NGDP,resumen-gdp=bde:DSPC102020VB1QB00_SS1_TSCTVA.T,digital-oecd-dgi=oecd:GOV_DGOGD_2025:DG:ESP,digital-oecd-ourdata=oecd:GOV_DGOGD_2025:OUR:ESP,fmi-gdp-growth=fmi:ESP:NGDP_RPCH,fmi-inflation=fmi:ESP:PCPIPCH,fmi-unemployment=fmi:ESP:LUR
SCHEDULER_ENABLED=false
SCHEDULER_TIMEZONE=Europe/Madrid
SCHEDULER_INGEST_INE_ENABLED=true
SCHEDULER_INGEST_BDE_ENABLED=true
SCHEDULER_INGEST_OECD_ENABLED=true
SCHEDULER_INGEST_FMI_ENABLED=true
# Cron (5 campos): minuto hora dia_mes mes dia_semana
SCHEDULER_INGEST_INE_CRON=15 6 * * *
SCHEDULER_INGEST_BDE_CRON=45 6 * * 1,3,5
SCHEDULER_INGEST_OECD_CRON=30 7 * * 1
SCHEDULER_INGEST_FMI_CRON=40 7 * * 1
# Códigos de series BdE separados por coma (requerido para ingesta programada BdE)
SCHEDULER_BDE_CODES=
# Códigos OECD separados por coma (formato corto soportado por pipeline OECD)
SCHEDULER_OECD_CODES=GOV_DGOGD_2025:DG:ESP,GOV_DGOGD_2025:OUR:ESP
# Códigos FMI (DataMapper) separados por coma
SCHEDULER_FMI_CODES=NGDP_RPCH,PCPIPCH,LUR,GGXWDG_NGDP,GGXCNL_NGDP
CORS_ALLOW_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
# Format: "token1:admin,token2:editor,token3:viewer"
API_KEYS=
API_DEFAULT_ROLE=viewer
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Public frontend (Next.js) facade
NEXT_PUBLIC_STORIES_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Identificación legal en la fachada pública (RGPD / aviso legal)
NEXT_PUBLIC_LEGAL_ENTITY_NAME=
NEXT_PUBLIC_LEGAL_ENTITY_TAX_ID=
NEXT_PUBLIC_LEGAL_ENTITY_ADDRESS=
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_DPO_EMAIL=

# Analítica (solo si el visitante acepta en el banner)
# NEXT_PUBLIC_ANALYTICS_PROVIDER=none | plausible | ga4
NEXT_PUBLIC_ANALYTICS_PROVIDER=none
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
